# Base da API de tráfego (Meta Graph) — server-side, no próprio subdomínio.
#
# Vazio = same-domain: os requests vão para /api/* relativo a
# supremapizza.fenicelab.com.br (a VPS precisa servir /api/insights, /api/saldo,
# /api/campaigns, /api/ads, /api/timeseries, /api/breakdown, etc).
# O TOKEN do Meta Graph fica SÓ no servidor (nunca aqui, nunca no front).
#
# Para apontar pra outro host (ex: durante migração), preencha com o host completo
# SEM /api no fim (o código já concatena /api/...): ex VITE_TRAFEGO_URL=https://relatorios.fenicelab.com.br
VITE_TRAFEGO_URL=

# Supabase (opcional) — só habilita sessão/RBAC e o botão "Criar campanha".
# Sem isto, o war room funciona em modo leitura (sem criar/escalar campanha).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
