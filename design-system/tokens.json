{
  "$description": "Suprema Pizza — Design Tokens (W3C DTCG). Derivado de design-system/colors_and_type.css (fonte canônica --sup-*). Fenice Lab · Onda 1 · 2026.",
  "color": {
    "$type": "color",
    "carvao":      { "$value": "#0F0F0F", "$description": "Fundo principal (tema escuro)" },
    "grafite":     { "$value": "#161616", "$description": "Cards / superfície alternativa" },
    "grafite-2":   { "$value": "#1F1F1F", "$description": "Superfície elevada / inputs" },
    "grafite-3":   { "$value": "#2A2A2A", "$description": "Hover de superfície" },
    "preto":       { "$value": "#000000", "$description": "Moldura cinematográfica" },

    "vermelho":    { "$value": "#D62828", "$description": "Primária — SUPREMA, CTAs" },
    "vermelho-dk": { "$value": "#B71C1C", "$description": "Press / hover escuro" },
    "vermelho-lt": { "$value": "#E84B4B", "$description": "Hover claro / foco" },
    "brasa":       { "$value": "#C0392B", "$description": "Badge ao vivo / alerta" },

    "branco":      { "$value": "#FFFFFF", "$description": "Texto primário sobre escuro" },
    "cinza":       { "$value": "#9A9A9A", "$description": "Texto secundário" },
    "cinza-esc":   { "$value": "#6E6E6E", "$description": "Decorativo / desativado — NÃO usar em texto legível (reprova AA sobre carvão)" },
    "cinza-leg":   { "$value": "#B0B0B0", "$description": "Legenda LEGÍVEL — contraste >=6:1 sobre carvão (AA)" },

    "bege":        { "$value": "#FFEBDC", "$description": "Halo de legenda social (cor de massa) — só sobre foto" },
    "bege-tinta":  { "$value": "#1A1A1A", "$description": "Texto preto dentro do halo bege" },

    "ok":          { "$value": "#3FB950", "$description": "Status: sucesso" },
    "aviso":       { "$value": "#E3A008", "$description": "Status: aviso" },
    "erro":        { "$value": "#D62828", "$description": "Status: erro" }
  },

  "border": {
    "linha":       { "$type": "color", "$value": "rgba(255,255,255,0.08)", "$description": "Divisor sutil" },
    "linha-forte": { "$type": "color", "$value": "rgba(255,255,255,0.16)", "$description": "Divisor forte" }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "corpo":   { "$value": ["Poppins", "system-ui", "-apple-system", "sans-serif"], "$description": "Texto corrido" },
      "display": { "$value": ["Saira Condensed", "Poppins", "system-ui", "sans-serif"], "$description": "Títulos caixa-alta condensada pesada / wordmark" }
    },
    "weight": {
      "$type": "fontWeight",
      "light": { "$value": 300 },
      "reg":   { "$value": 400 },
      "med":   { "$value": 500 },
      "semi":  { "$value": 600 },
      "bold":  { "$value": 700 },
      "black": { "$value": 800 }
    }
  },

  "spacing": {
    "$type": "dimension",
    "s1": { "$value": "4px" },
    "s2": { "$value": "8px" },
    "s3": { "$value": "12px" },
    "s4": { "$value": "16px" },
    "s5": { "$value": "24px" },
    "s6": { "$value": "32px" },
    "s7": { "$value": "48px" },
    "s8": { "$value": "64px" }
  },

  "radius": {
    "$type": "dimension",
    "sm":   { "$value": "6px" },
    "md":   { "$value": "10px" },
    "lg":   { "$value": "16px" },
    "xl":   { "$value": "24px" },
    "pill": { "$value": "999px" }
  },

  "shadow": {
    "$type": "shadow",
    "sh-1": { "$value": { "offsetX": "0px", "offsetY": "1px",  "blur": "2px",  "spread": "0px", "color": "rgba(0,0,0,0.4)" } },
    "sh-2": { "$value": { "offsetX": "0px", "offsetY": "8px",  "blur": "24px", "spread": "0px", "color": "rgba(0,0,0,0.45)" } },
    "sh-3": { "$value": { "offsetX": "0px", "offsetY": "18px", "blur": "48px", "spread": "0px", "color": "rgba(0,0,0,0.6)" } }
  },

  "motion": {
    "ease":   { "$type": "cubicBezier", "$value": [0.2, 0.7, 0.3, 1] },
    "dur":    { "$type": "duration", "$value": "180ms" },
    "dur-lg": { "$type": "duration", "$value": "400ms" }
  }
}
